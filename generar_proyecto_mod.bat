echo         activeEvents.remove(targetId);>> "%PF%"
echo         Queue<Runnable> queue = eventQueues.get(targetId);>> "%PF%"
echo         if (queue != null && !queue.isEmpty()) {>> "%PF%"
echo             Runnable next = queue.poll();>> "%PF%"
echo             activeEvents.put(targetId, next);>> "%PF%"
echo             next.run();>> "%PF%"
echo         }>> "%PF%"
echo     }>> "%PF%"
echo     public boolean hasActiveEvent(UUID targetId) { return activeEvents.containsKey(targetId); }>> "%PF%"
