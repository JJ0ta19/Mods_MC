echo public class EventQueueManager {>> "%PF%"
echo     private final Map<UUID, Queue<Runnable>> eventQueues = new HashMap<>();>> "%PF%"
echo     private final Map<UUID, Runnable> activeEvents = new HashMap<>();>> "%PF%"
echo     public void queueOrExecute(UUID targetId, Runnable event) {>> "%PF%"
echo         if (activeEvents.containsKey(targetId)) {>> "%PF%"
echo             eventQueues.computeIfAbsent(targetId, k -> new LinkedList<>()).add(event);>> "%PF%"
