echo # Como compilar el mod a JAR>> "%PF%"
echo.>> "%PF%"
echo Instrucciones para compilar un mod de Forge 1.20.1 usando Gradle.>> "%PF%"
echo.>> "%PF%"
echo ## Requisitos>> "%PF%"
echo.>> "%PF%"
echo | Requisito | Version |>> "%PF%"
echo |-----------|---------|>> "%PF%"
echo | Java JDK | 17 o superior |>> "%PF%"
echo | Gradle | 8.1.1 (incluido en gradlew.bat) |>> "%PF%"
echo | Git | Opcional |>> "%PF%"
echo.>> "%PF%"
echo Verifica Java: `java -version`>> "%PF%"
echo Debe mostrar `openjdk version "17.0.x"` o superior.>> "%PF%"
echo.>> "%PF%"
echo ## Compilar el JAR>> "%PF%"
echo.>> "%PF%"
echo 1. Abre una terminal en la carpeta del proyecto>> "%PF%"
echo 2. Ejecuta `.\gradlew.bat` (descarga Gradle y Forge, primera vez tarda)>> "%PF%"
echo 3. Ejecuta `.\gradlew.bat build`>> "%PF%"
echo 4. El JAR esta en `build/libs/<modid>-1.0.0.jar`>> "%PF%"
echo.>> "%PF%"
echo ## Instalar el mod>> "%PF%"
echo.>> "%PF%"
echo 1. Copia el `.jar` a la carpeta `mods/` de tu Minecraft>> "%PF%"
echo 2. Forge 1.20.1 debe estar instalado en el perfil>> "%PF%"
echo 3. Inicia Minecraft>> "%PF%"
echo.>> "%PF%"
echo ## Comandos utiles>> "%PF%"
echo.>> "%PF%"
echo | Comando | Que hace |>> "%PF%"
echo |---------|----------|>> "%PF%"
echo | `.\gradlew.bat build` | Compila el JAR |>> "%PF%"
echo | `.\gradlew.bat clean` | Borra build/ |>> "%PF%"
echo | `.\gradlew.bat runClient` | Ejecuta Minecraft |>> "%PF%"
echo | `.\gradlew.bat runServer` | Ejecuta servidor |>> "%PF%"
echo | `.\gradlew.bat --stop` | Detiene el daemon de Gradle |>> "%PF%"
echo.>> "%PF%"
echo ## Solucion de problemas>> "%PF%"
echo.>> "%PF%"
echo - **Java not found**: Configura JAVA_HOME en tus variables de entorno>> "%PF%"
echo - **Out of memory**: Edita `gradle.properties`, aumenta -Xmx>> "%PF%"
echo - **BUILD FAILED**: Revisa errores de compilacion en la terminal>> "%PF%"
echo - **JAR no funciona**: Verifica mods.toml, @Mod, MODID>> "%PF%"
echo '@>> "%PF%"
echo.>> "%PF%"

echo w 'COMO_AGREGAR_SONIDOS.md' @'>> "%PF%"
echo # Como agregar sonidos al mod>> "%PF%"
echo.>> "%PF%"
echo Basado en el sistema de sonidos del mod Rasengan (Forge 1.20.1, Mojang mappings).>> "%PF%"
echo.>> "%PF%"
echo ## Archivos a tocar (4)>> "%PF%"
echo.>> "%PF%"
echo | Archivo | Proposito |>> "%PF%"
echo |---------|-----------|>> "%PF%"
echo | `ModSounds.java` | Registrar el SoundEvent |>> "%PF%"
echo | `sounds.json` | Mapear ID del sonido al .ogg |>> "%PF%"
echo | `.ogg` file | El audio en `assets/<modid>/sounds/` |>> "%PF%"
echo | Tu codigo | Reproducir sonido con `playSound()` |>> "%PF%"
echo.>> "%PF%"
echo ## 1. Prepara tu audio (.ogg)>> "%PF%"
echo.>> "%PF%"
echo Usa Audacity o FFmpeg para convertir a OGG Vorbis.>> "%PF%"
echo Guarda en: `src/main/resources/assets/<modid>/sounds/entity/<nombre>.ogg`>> "%PF%"
echo.>> "%PF%"
echo ## 2. Registra el SoundEvent en ModSounds.java>> "%PF%"
echo.>> "%PF%"
echo ```java>> "%PF%"
echo public static final RegistryObject<SoundEvent> MI_SONIDO =>> "%PF%"
echo         SOUNDS.register("mi_sonido",>> "%PF%"
echo             () -> SoundEvent.createVariableRangeEvent(>> "%PF%"
echo                 new ResourceLocation(ModID, "mi_sonido")));>> "%PF%"
echo ```>> "%PF%"
echo.>> "%PF%"
echo ## 3. Crea sounds.json>> "%PF%"
echo.>> "%PF%"
echo Ubicacion: `src/main/resources/assets/<modid>/sounds.json`>> "%PF%"
echo.>> "%PF%"
echo ```json>> "%PF%"
echo { "mi_sonido": {>> "%PF%"
echo     "subtitle": "Mi sonido",>> "%PF%"
echo     "sounds": [ "<modid>:entity/mi_sonido" ]>> "%PF%"
echo } }>> "%PF%"
echo ```>> "%PF%"
echo.>> "%PF%"
echo ## 4. Reproduce el sonido>> "%PF%"
echo.>> "%PF%"
echo ```java>> "%PF%"
echo level().playSound(null, x, y, z,>> "%PF%"
echo     ModSounds.MI_SONIDO.get(), SoundSource.PLAYERS, 3.0f, 1.0f);>> "%PF%"
echo ```>> "%PF%"
echo.>> "%PF%"
echo Parametros: `null`=todos, `x,y,z`=posicion, `SoundEvent`, `SoundSource`, `volume`, `pitch`>> "%PF%"
echo '@>> "%PF%"
echo.>> "%PF%"

echo w 'COMO_CREAR_NUEVA_ENTIDAD.md' @'>> "%PF%"
echo # Como crear una nueva entidad (basada en Stickman)>> "%PF%"
echo.>> "%PF%"
echo Guia paso a paso para crear un personaje similar al Stickman (Naruto).>> "%PF%"
echo.>> "%PF%"
echo ## Archivos a crear (6)>> "%PF%"
echo.>> "%PF%"
echo | Archivo | Proposito |>> "%PF%"
echo |---------|-----------|>> "%PF%"
echo | `MiPersonajeEntity.java` | Logica de la entidad |>> "%PF%"
echo | `client/MiPersonajeModel.java` | Modelo 3D humanoide |>> "%PF%"
echo | `client/MiPersonajeRenderer.java` | Render con skin |>> "%PF%"
echo | `textures/entity/mi_personaje.png` | Skin PNG 64x64 |>> "%PF%"
echo | Modificar `ModEntities.java` | Registrar la entidad |>> "%PF%"
echo | Modificar clase principal | Registrar render + comando |>> "%PF%"
echo.>> "%PF%"
echo ## 1. Crea la textura (PNG 64x64)>> "%PF%"
echo.>> "%PF%"
echo Usa el layout UV vanilla: Head(0,0), Body(16,16), Arms(40,16), Legs(0,16)>> "%PF%"
echo Guarda en `assets/<modid>/textures/entity/mi_personaje.png`>> "%PF%"
echo.>> "%PF%"
echo ## 2. Crea el modelo (MiPersonajeModel.java)>> "%PF%"
echo.>> "%PF%"
echo Extiende EntityModel. Usa ModelLayerLocation. Define partes: head, body, rightArm, leftArm, rightLeg, leftLeg.>> "%PF%"
echo En setupAnim() controla la animacion segun getAnimState():>> "%PF%"
echo - 0: quieto>> "%PF%"
echo - 1: cargando (brazo derecho levantado)>> "%PF%"
echo - 2: lanzo (cuerpo inclinado)>> "%PF%"
echo.>> "%PF%"
echo ## 3. Crea el Renderer (MiPersonajeRenderer.java)>> "%PF%"
echo.>> "%PF%"
echo Extiende EntityRenderer. En render(): escala -1x-1x1, rota hacia el jugador, llama model.renderToBuffer().>> "%PF%"
echo Para skins multiples, usa un array de ResourceLocation y un skinIndex.>> "%PF%"
echo.>> "%PF%"
echo ## 4. Crea la entidad (MiPersonajeEntity.java)>> "%PF%"
echo.>> "%PF%"
echo Extiende Entity. Usa SynchedEntityData para ANIM_STATE y RASENGAN_ID.>> "%PF%"
echo En tick():>> "%PF%"
echo - Fase carga (100 ticks): animState=1, genera Rasengan en la mano>> "%PF%"
echo - Fase lanzamiento: animState=2, da velocidad al Rasengan hacia el target>> "%PF%"
echo - Fase sigue: se mueve con el Rasengan hasta que desaparezca>> "%PF%"
echo.>> "%PF%"
echo ## 5. Registra en ModEntities.java>> "%PF%"
echo.>> "%PF%"
echo Agrega: `ENTITIES.register("mi_personaje", () -> EntityType.Builder.of(...))`>> "%PF%"
echo.>> "%PF%"
echo ## 6. Registra el renderer en la clase principal>> "%PF%"
echo.>> "%PF%"
echo En ClientModEvents: registerEntityRenderer + registerLayerDefinition>> "%PF%"
echo.>> "%PF%"
echo ## 7. Crea un comando>> "%PF%"
echo.>> "%PF%"
echo Usa Commands.literal("mipersonaje") con EVENT_QUEUE.queueOrExecute()>> "%PF%"
echo.>> "%PF%"
echo ```java>> "%PF%"
echo // Ejemplo de comando>> "%PF%"
echo dispatcher.register(Commands.literal("mipersonaje")>> "%PF%"
echo     .executes(ctx -> {>> "%PF%"
echo         ServerPlayer sender = (ServerPlayer) ctx.getSource().getEntity();>> "%PF%"
echo         MiPersonajeEntity e = ModEntities.MI_PERSONAJE.get().create(sender.serverLevel());>> "%PF%"
echo         e.setPos(sender.position()); e.setTarget(sender);>> "%PF%"
echo         sender.serverLevel().addFreshEntity(e);>> "%PF%"
echo         return 1;>> "%PF%"
echo     }));>> "%PF%"
echo ```>> "%PF%"
echo '@>> "%PF%"

